{
  "sourceLanguage" : "ja",
  "strings" : {
    "%" : {
      "comment" : "A unit of measurement for a percentage.",
      "isCommentAutoGenerated" : true
    },
    "%@ / %lld" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ / %2$lld"
          }
        }
      }
    },
    "%@ にログインリンクを送りました。受信トレイをご確認ください。" : {
      "comment" : "A footer at the bottom of the login view that informs the user that a login link has been sent to their email address, and to check their inbox. The dynamic text inside the parentheses will be replaced with the actual",
      "isCommentAutoGenerated" : true
    },
    "%lld" : {
      "comment" : "A label showing the index of a question in a list. The argument is the index of the question.",
      "isCommentAutoGenerated" : true
    },
    "%lld / %lld" : {
      "comment" : "A label showing the current question index and total question count.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld / %2$lld"
          }
        }
      }
    },
    "%lld / %lld 正解" : {
      "comment" : "A label displaying the number of correct answers out of the total number of questions. The first argument is the count of correct answers. The second argument is the total count of questions.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld / %2$lld 正解"
          }
        }
      }
    },
    "⚠️ Apple と Web の両方に有効なサブスクリプションがあります。重複課金を避けるため、片方を解約してください。" : {
      "comment" : "A warning message indicating that a user has a subscription that is valid on both the App Store and the Stripe website. It advises the user to cancel one of them to prevent duplicate charges.",
      "isCommentAutoGenerated" : true
    },
    "⚠︎ figure missing: %@" : {
      "comment" : "A warning label when a figure image is missing from the app bundle. The placeholder text is replaced with the actual path of the missing image.",
      "isCommentAutoGenerated" : true
    },
    "¥980 / 月 または年額プラン" : {
      "comment" : "The price of the Pro plan, displayed to the user.",
      "isCommentAutoGenerated" : true
    },
