# Copy to .env.local (not committed) and fill in.

# Vercel AI Gateway (https://vercel.com/d?to=%2F%5Bteam%5D%2F%7E%2Fai-gateway%2Fapi-keys)
AI_GATEWAY_API_KEY=vck_...

# Model string for the gateway. See:
#   curl -s https://ai-gateway.vercel.sh/v1/models | jq -r '.data[].id'
AI_MODEL=google/gemini-3-flash

# Supabase (https://supabase.com → project settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # server-side only, never expose to client

# Dev-only: treat every signed-in user as Pro, bypassing subscription_status.
# Remove before shipping Stripe. Set only in local dev.
DEV_FORCE_PRO=true

# Stripe (subscription billing). Create products + prices in Stripe Dashboard,
# then add a webhook endpoint pointing at /api/webhooks/stripe.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...           # Pro monthly price
STRIPE_PRICE_ID_ANNUAL=             # optional Pro annual price

# Public site URL — used for Stripe Checkout success/cancel URLs and the
# sitemap base. Set per environment.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Search Console verification token. Register the domain in Search
# Console (HTML tag method), copy the `content="..."` value, set this on
# Vercel for production. Leave empty in dev — when unset no verification
# meta tag is emitted.
GOOGLE_SITE_VERIFICATION=
